#!/usr/bin/env bash

set -u

target_pane="${1:-${TMUX_PANE:-}}"
target_client="${2:-}"
script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
script_path="$script_dir/$(basename -- "${BASH_SOURCE[0]}")"
script_shell="$(printf '%q' "$script_path")"

pause() {
  local key

  printf '\nPress Ctrl-g to close...'
  while IFS= read -rsn1 key; do
    [[ "$key" == $'\a' ]] && break
  done
}

strip_ansi() {
  if command -v perl >/dev/null 2>&1; then
    perl -pe 's/\e\[[0-9;?]*[ -\/]*[@-~]//g'
  else
    cat
  fi
}

trim() {
  local value="$1"
  value="${value#"${value%%[![:space:]]*}"}"
  value="${value%"${value##*[![:space:]]}"}"
  printf '%s' "$value"
}

extract_command() {
  local line="$1"
  local cmdline token command=""
  local bare_command_re='^[[:space:]]*([[:alnum:]_.+-]+)([[:space:]]|$)'

  cmdline="$(trim "$line")"

  # Strip common shell prompt markers, keeping the typed command.
  if [[ "$cmdline" == *"\$ "* || "$cmdline" == *"# "* || "$cmdline" == *"% "* ]]; then
    cmdline="${cmdline##*\$ }"
    cmdline="${cmdline##*# }"
    cmdline="${cmdline##*% }"
  elif [[ "$cmdline" == *"❯ "* ]]; then
    cmdline="${cmdline##*❯ }"
  elif [[ "$cmdline" == *"> "* ]]; then
    cmdline="${cmdline##*> }"
  elif [[ "$cmdline" =~ $bare_command_re ]]; then
    cmdline="${BASH_REMATCH[1]}"
  else
    printf ''
    return
  fi

  read -r -a tokens <<< "$cmdline"

  local wrapper_seen=0
  for token in "${tokens[@]}"; do
    token="${token%%[;&|]*}"
    token="${token##[({]}"
    token="${token%%[)}]}"

    [[ -z "$token" ]] && continue
    [[ "$token" =~ ^[A-Za-z_][A-Za-z0-9_]*= ]] && continue

    case "$token" in
      sudo|doas|env|command|builtin|exec|time|nice|nohup)
        wrapper_seen=1
        continue
        ;;
    esac

    if [[ "$wrapper_seen" -eq 1 && "$token" == -* ]]; then
      continue
    fi

    command="${token##*/}"
    command="${command//[^A-Za-z0-9_.+-]/}"
    break
  done

  printf '%s' "$command"
}

capture_visible_pane() {
  tmux capture-pane -p -J -S 0 -E - -t "$target_pane" 2>/dev/null | strip_ansi
}

find_command_at_cursor() {
  local cursor_y line command
  local -a lines

  cursor_y="$(tmux display-message -p -t "$target_pane" '#{cursor_y}' 2>/dev/null)"
  [[ "$cursor_y" =~ ^[0-9]+$ ]] || cursor_y=""

  mapfile -t lines < <(capture_visible_pane)

  if [[ -n "$cursor_y" && "${lines[$cursor_y]+set}" == "set" ]]; then
    line="${lines[$cursor_y]}"
    command="$(extract_command "$line")"
    if [[ -n "$command" ]]; then
      printf '%s\t%s\n' "$command" "$line"
      return
    fi
  fi

  local start="${cursor_y:-$((${#lines[@]} - 1))}"
  local i
  for ((i = start; i >= 0; i--)); do
    line="${lines[$i]}"
    [[ "$line" == *"\$ "* || "$line" == *"# "* || "$line" == *"% "* || "$line" == *"❯ "* || "$line" == *"> "* ]] || continue

    command="$(extract_command "$line")"
    if [[ -n "$command" ]]; then
      printf '%s\t%s\n' "$command" "$line"
      return
    fi
  done
}

render_tldr() {
  local command="$1"

  if ! command -v tldr >/dev/null 2>&1; then
    printf 'The tldr command is not installed or is not on PATH.\n'
    return 1
  fi

  if ! tldr -m "$command" | awk '
    function clean(value) {
      gsub(/\{\{/, "", value)
      gsub(/\}\}/, "", value)
      gsub(/^`/, "", value)
      gsub(/`$/, "", value)
      gsub(/^> /, "", value)
      gsub(/^<|>.$/, "", value)
      return value
    }

    /^# / {
      title = substr($0, 3)
      printf "\033[1;36mtldr %s\033[0m\n", title
      next
    }

    /^> / {
      text = clean($0)
      if (text ~ /^More information:/) {
        gsub(/^More information: /, "More: ", text)
        gsub(/[<>]/, "", text)
        printf "\033[2m%s\033[0m\n\n", text
      } else {
        printf "%s\n", text
      }
      next
    }

    /^- / {
      explanation = substr($0, 3)
      sub(/:$/, "", explanation)
      next
    }

    /^`/ {
      example = clean($0)
      printf "  \033[1;32m%s\033[0m\n", example
      if (explanation != "") {
        printf "    %s\n\n", explanation
      }
      explanation = ""
      next
    }

    /^Found / {
      printf "\033[2m%s\033[0m\n", $0
    }
  '; then
    printf '\nNo tldr page was found for "%s".\n' "$command"
    return 1
  fi
}

pane_exists() {
  tmux display-message -p -t "$1" '#{pane_id}' >/dev/null 2>&1
}

close_existing_help_panes() {
  local window_id pane_id pane_title pane_start_command closed=0

  window_id="$(tmux display-message -p -t "$target_pane" '#{window_id}' 2>/dev/null)"
  [[ -n "$window_id" ]] || return 1

  while IFS=$'\t' read -r pane_id pane_title pane_start_command; do
    if [[ "$pane_title" != ttldr:* &&
          "$pane_title" != tmux-tldr:* &&
          "$pane_title" != tldr:* &&
          "$pane_start_command" != *"ttldr --render-pane"* &&
          "$pane_start_command" != *"ttldr --message-pane"* &&
          "$pane_start_command" != *"tmux-tldr-popup --render-pane"* &&
          "$pane_start_command" != *"tmux-tldr-popup --message-pane"* ]]; then
      continue
    fi

    tmux kill-pane -t "$pane_id"
    closed=1
  done < <(tmux list-panes -t "$window_id" -F '#{pane_id}	#{pane_title}	#{pane_start_command}')

  [[ "$closed" -eq 1 ]]
}

render_pane_footer() {
  printf '\n\033[2mCtrl-g closes this cheatsheet. Your shell pane stays active while this is open.\033[0m\n'
  while :; do
    sleep 3600
  done
}

help_pane_size() {
  local client_width

  client_width="$(tmux display-message -p -t "$target_pane" '#{client_width}' 2>/dev/null)"

  if [[ ! "$client_width" =~ ^[0-9]+$ ]]; then
    printf '38%%'
  elif ((client_width >= 220)); then
    printf '92'
  elif ((client_width >= 180)); then
    printf '84'
  elif ((client_width >= 140)); then
    printf '72'
  else
    printf '42%%'
  fi
}

open_help_pane() {
  local title="$1"
  local shell_command="$2"
  local help_pane size

  size="$(help_pane_size)"

  tmux set-window-option -t "$target_pane" pane-border-status top >/dev/null
  tmux set-window-option -t "$target_pane" pane-border-format ' #{pane_title} ' >/dev/null
  tmux set-window-option -t "$target_pane" pane-border-lines single >/dev/null
  tmux set-window-option -t "$target_pane" pane-border-style 'fg=colour240' >/dev/null
  tmux set-window-option -t "$target_pane" pane-active-border-style 'fg=colour75' >/dev/null

  help_pane="$(tmux split-window -d -h -f -l "$size" \
    -t "$target_pane" \
    -F '#{pane_id}' \
    "$shell_command")"

  if [[ -n "$help_pane" ]]; then
    printf '%s\n' "$help_pane" > "$marker"
    [[ -n "${window_marker:-}" ]] && printf '%s\n' "$help_pane" > "$window_marker"
    tmux select-pane -T "ttldr:$title" -t "$help_pane"
    tmux select-pane -t "$target_pane"
  fi
}

if [[ "${1:-}" == "--message" ]]; then
  printf '%s\n\n%s\n' \
    "Could not detect a command near the cursor." \
    "Type a command like ls, or run a command and press Ctrl-g while its prompt line is still visible."
  pause
  exit 0
fi

if [[ "${1:-}" == "--message-pane" ]]; then
  marker="${2:-}"
  [[ -n "$marker" ]] && trap 'rm -f "$marker"' EXIT

  printf '%s\n\n%s\n' \
    "Could not detect a command near the cursor." \
    "Type a command like ls, or run a command and press Ctrl-g while its prompt line is still visible."
  render_pane_footer
  exit 0
fi

if [[ "${1:-}" == "--render" ]]; then
  command="${2:-}"

  if [[ -z "$command" ]]; then
    printf 'No command was provided.\n'
    pause
    exit 1
  fi

  render_tldr "$command"
  pause

  exit 0
fi

if [[ "${1:-}" == "--render-pane" ]]; then
  command="${2:-}"
  marker="${3:-}"
  [[ -n "$marker" ]] && trap 'rm -f "$marker"' EXIT

  if [[ -z "$command" ]]; then
    printf 'No command was provided.\n'
  else
    render_tldr "$command"
  fi

  render_pane_footer
  exit 0
fi

if [[ "${1:-}" == "--debug-panes" ]]; then
  target_pane="${2:-${TMUX_PANE:-}}"
  window_id="$(tmux display-message -p -t "$target_pane" '#{window_id}' 2>/dev/null)"
  tmux list-panes -t "$window_id" -F '#{pane_id} | title=#{pane_title} | cmd=#{pane_current_command} | start=#{pane_start_command}'
  exit 0
fi

if [[ -z "$target_pane" ]]; then
  printf 'No tmux pane was provided.\n'
  pause
  exit 1
fi

marker_id="${target_client:-$target_pane}"
marker_id="${marker_id//[^A-Za-z0-9_.-]/_}"
marker="/tmp/ttldr-${marker_id}"
target_window_id="$(tmux display-message -p -t "$target_pane" '#{window_id}' 2>/dev/null)"
window_marker_id="${target_window_id//[^A-Za-z0-9_.-]/_}"
window_marker="/tmp/ttldr-window-${window_marker_id}"

if close_existing_help_panes; then
  rm -f "$marker" "$window_marker"
  exit 0
fi

for possible_marker in "$window_marker" "$marker"; do
  [[ -s "$possible_marker" ]] || continue
  existing_pane="$(<"$possible_marker")"
  rm -f "$marker" "$window_marker"
  if pane_exists "$existing_pane"; then
    tmux kill-pane -t "$existing_pane"
    exit 0
  fi
done

rm -f "$marker" "$window_marker"

result="$(find_command_at_cursor)"
command="${result%%$'\t'*}"
line="${result#*$'\t'}"
if [[ "$line" == "$result" ]]; then
  line=""
fi

if [[ -z "$command" ]]; then
  marker_shell="$(printf '%q' "$marker")"
  open_help_pane "tldr: no command" "$script_shell --message-pane $marker_shell"
  exit 1
fi

command_shell="$(printf '%q' "$command")"
marker_shell="$(printf '%q' "$marker")"
open_help_pane "tldr: $command" "$script_shell --render-pane $command_shell $marker_shell"
